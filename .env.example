# Reflex — environment for the MCP client
#
# Copy to .env and set your Doable API key:
#     cp .env.example .env
#     # edit .env, then in the shell you launch your agent from:
#     set -a; source .env; set +a
#
# This is the ONLY value you need. It is forwarded to Doable by the Reflex
# backend and is never persisted or logged. .env is gitignored.

QA_DOABLE_API_KEY=
